"""
Reproduces Figure 2 (ECRL Training Dynamics) from released training logs.

Usage:
    python results/figures/make_figure2.py --logs results/raw_logs/ecrl_s1/

Expects training logs in JSON-lines format, one file per seed, with fields:
    episode, ethical_return, delta_dp, delta_eo, lambda_f, lambda_t
matching the output schema of src/training/ecrl.py's logger callback.
"""

import argparse
import json
from pathlib import Path

import numpy as np
import matplotlib.pyplot as plt
from matplotlib.ticker import MultipleLocator
from scipy.ndimage import gaussian_filter1d


def load_seed_logs(log_dir: Path) -> list[dict]:
    seed_files = sorted(log_dir.glob("seed_*.jsonl"))
    if not seed_files:
        raise FileNotFoundError(
            f"No seed_*.jsonl files found in {log_dir}. "
            "Run training with 5 seeds first, or download released logs "
            "from the Hugging Face Hub link in the top-level README."
        )
    all_logs = []
    for f in seed_files:
        with open(f) as fh:
            all_logs.append([json.loads(line) for line in fh])
    return all_logs


def aggregate_across_seeds(logs: list[list[dict]], field: str) -> tuple[np.ndarray, np.ndarray, np.ndarray]:
    episodes = np.array([entry["episode"] for entry in logs[0]])
    values = np.array([[entry[field] for entry in seed_log] for seed_log in logs])
    return episodes, values.mean(axis=0), values.std(axis=0)


def make_figure2(log_dir: str, output_path: str = "figure2_ECRL_training.png"):
    logs = load_seed_logs(Path(log_dir))

    plt.rcParams.update({
        "font.family": "serif", "font.serif": ["DejaVu Serif"],
        "mathtext.fontset": "dejavuserif",
        "axes.spines.top": False, "axes.spines.right": False,
    })

    fig, axes = plt.subplots(1, 3, figsize=(15, 4.8))

    ep, mean_ret, std_ret = aggregate_across_seeds(logs, "ethical_return")
    axes[0].fill_between(ep, mean_ret - std_ret, mean_ret + std_ret, alpha=0.3)
    axes[0].plot(ep, gaussian_filter1d(mean_ret, sigma=3))
    axes[0].set_title("(a)", loc="left", fontweight="bold")
    axes[0].set_xlabel("Episode")
    axes[0].set_ylabel(r"Ethical Return $V(\pi_k)$")

    ep, mean_dp, std_dp = aggregate_across_seeds(logs, "delta_dp")
    axes[1].fill_between(ep, mean_dp - std_dp, mean_dp + std_dp, alpha=0.3)
    axes[1].plot(ep, gaussian_filter1d(mean_dp, sigma=3))
    axes[1].axhline(0.05, ls="--", color="black", alpha=0.6,
                    label=r"$\varepsilon_{DP}=0.05$")
    axes[1].set_title("(b)", loc="left", fontweight="bold")
    axes[1].set_xlabel("Episode")
    axes[1].set_ylabel(r"Parity Gap $\Delta_{DP}$")
    axes[1].legend(frameon=False)

    ep, mean_lf, std_lf = aggregate_across_seeds(logs, "lambda_f")
    axes[2].fill_between(ep, mean_lf - std_lf, mean_lf + std_lf, alpha=0.3)
    axes[2].plot(ep, gaussian_filter1d(mean_lf, sigma=3))
    axes[2].set_title("(c)", loc="left", fontweight="bold")
    axes[2].set_xlabel("Episode")
    axes[2].set_ylabel(r"Lagrange Multiplier $\lambda_f$")

    plt.tight_layout()
    plt.savefig(output_path, dpi=400, bbox_inches="tight")
    print(f"Figure saved to {output_path}")


if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument("--logs", type=str, required=True,
                        help="Directory containing seed_*.jsonl training logs")
    parser.add_argument("--output", type=str, default="figure2_ECRL_training.png")
    args = parser.parse_args()
    make_figure2(args.logs, args.output)
